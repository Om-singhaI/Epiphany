# Epiphany configuration — copy to `.env` and fill in what you have.
# Every provider is OPTIONAL: leave blank to run that step in simulation mode.

# Epiphany configuration — copy to `.env` and fill in what you have.
#
# The ONLY thing you need to do real data science is point Epiphany at a dataset
# (DATA_CSV_PATH below, which already defaults to the bundled data/train.csv) and
# — optionally — add a Gemini API key so the agent phrases its own hypotheses.
# Every external provider is optional; without one, that step uses the real local
# data instead of failing.

# ── General ──────────────────────────────────────────────────────────────
APP_ENV=development
# Skip all live network providers and analyse the local dataset only. Analysis
# stays REAL — only the external calls are disabled. Great for offline demos.
FORCE_SIMULATION=false
# Safety guard: only open REAL GitLab merge requests when this is true. Local
# outputs (trained model + findings report) are always produced regardless.
AUTO_DEPLOY=false

# ── Autonomous loop ──────────────────────────────────────────────────────
# Run the agent continuously in the background. Disable on constrained hosts
# and trigger cycles on demand from the dashboard instead.
RUN_AUTONOMOUS_LOOP=true
AUTONOMOUS_INTERVAL_SECONDS=45

# ── Local data + outputs (the "anyone can use" path) ─────────────────────
# Point this at ANY CSV or Parquet file to analyse your own data.
DATA_CSV_PATH=data/train.csv
ARTIFACTS_DIR=artifacts
REPORTS_DIR=reports
SIGNIFICANCE_ALPHA=0.05

# ── Auth: Clerk (optional sign-in/up gate for the dashboard) ─────────────
# Create an app at https://dashboard.clerk.com and paste the Publishable Key.
# It's safe to expose to the browser. Leave blank to use the local demo login.
CLERK_PUBLISHABLE_KEY=

# ── Step 3: Reason — Gemini (recommended: just an API key) ───────────────
# Get a key at https://aistudio.google.com/apikey — no Google Cloud project.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Step 1: Trigger — Fivetran (optional) ────────────────────────────────
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
FIVETRAN_CONNECTOR_ID=
# FIVETRAN_BASE_URL=https://api.fivetran.com/v1

# ── Step 2: Explore — Elastic (optional; falls back to DATA_CSV_PATH) ─────
ELASTIC_CLOUD_ID=
ELASTIC_API_KEY=
# ELASTIC_URL=https://localhost:9200   # alternative to cloud id
ELASTIC_INDEX=prod_db.saas_telemetry

# ── Step 3 (enterprise alt): Vertex AI instead of an API key (optional) ───
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
# Path to a service-account JSON. If blank, Application Default Credentials
# are used (e.g. `gcloud auth application-default login`).
GOOGLE_APPLICATION_CREDENTIALS=

# ── Step 5: Deploy — GitLab (optional) ───────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
GITLAB_TARGET_BRANCH=main
