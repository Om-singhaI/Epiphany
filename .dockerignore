# Keep the image small and free of secrets / local state.
.venv/
venv/
__pycache__/
*.py[cod]
.git/
.gitignore

# Secrets — never bake these into the image
.env
*.env
epiphany_connections.json
epiphany-*.json
*-service-account*.json
service-account*.json
gcp-*.json
*.pem
*.key
credentials*.csv

# Local state / generated output
epiphany.db
epiphany.db.bak-*
*.sqlite*
artifacts/
reports/
data/uploads/

# Editor / OS / docs not needed at runtime
.DS_Store
.idea/
.vscode/
*.bak
REPORT.md
